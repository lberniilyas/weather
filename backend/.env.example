# Server
PORT=5000
NODE_ENV=development

# Database — Supabase (transaction pooler for app, direct URL for migrations)
# Get these from: Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# OpenWeatherMap API — https://openweathermap.org/api
# Free tier is sufficient (Current Weather + 5-Day Forecast endpoints)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# YouTube Data API v3 — https://console.cloud.google.com
# Enable "YouTube Data API v3" in Google Cloud Console
YOUTUBE_API_KEY=your_youtube_api_key_here

# CORS — URL of the frontend (no trailing slash)
CORS_ORIGIN=http://localhost:3000

# API Key — guards all write/delete operations on /api/records
# Must match NEXT_PUBLIC_API_KEY in frontend/.env.local
API_KEY=your_chosen_api_key_here
