# Server
PORT=5000
NODE_ENV=development

# Database — create a local PostgreSQL DB named weather_app
DATABASE_URL="postgresql://postgres:password@localhost:5432/weather_app"
# Direct connection used by Prisma migrations
DIRECT_URL="postgresql://postgres:password@localhost:5432/weather_app"
# OpenWeatherMap — https://openweathermap.org/api
OPENWEATHER_API_KEY=place_your_openweather_api_key_here

# YouTube Data API v3 — https://console.cloud.google.com
YOUTUBE_API_KEY=place_your_youtube_api_key_here

# CORS — URL of the frontend
CORS_ORIGIN=http://localhost:3000
API_KEY=place_your_api_key_here